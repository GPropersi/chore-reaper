{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vitest/globals", "@cloudflare/vitest-pool-workers/types"],
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src", "test", "scripts", "worker-configuration.d.ts"]
}
